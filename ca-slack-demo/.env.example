# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global

# --- Workspace (Optional) ---
# The ID of the Shared Drive to create sheets and slides in.
# If not set, they will be created in the user's root folder.
SHARED_DRIVE_ID=your-shared-drive-id

# --- Vertex AI ---
# Required: tells google-genai to use Vertex AI instead of the Gemini API.
# ADC (gcloud auth application-default login) provides credentials locally.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global    # must be "global" for gemini-3.1-flash-lite-preview

# --- Models ---
# Gemini model for the ADK root agent (routing decisions) and sub-agents
ROUTER_MODEL=gemini-3.1-flash-lite-preview
AGENT_MODEL=gemini-3.1-flash-lite-preview

# --- CA API Agent IDs ---
# Pre-created CA agents — one per BigQuery dataset.
# Add a new dataset by adding an AgentConfig to src/config.py and setting its env var here.
CA_AGENT_THELOOK=your-thelook-agent-id
CA_AGENT_STACKOVERFLOW=your-stackoverflow-agent-id
CA_AGENT_NCAA=your-ncaa-agent-id
CA_AGENT_CENSUS=your-census-agent-id
CA_AGENT_GA4=your-ga4-agent-id
CA_AGENT_GA360=your-ga360-agent-id

# --- Slack ---
# Create a Slack app at https://api.slack.com/apps
# See README.md for required scopes and setup steps.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- gRPC ---
# Forces gRPC to use the system DNS resolver instead of c-ares,
# which can fail to resolve googleapis.com endpoints.
GRPC_DNS_RESOLVER=native

# --- Optional ---
CHART_RENDER_SCALE=2.0
CA_CHAT_TIMEOUT_S=90
LOG_LEVEL=INFO
