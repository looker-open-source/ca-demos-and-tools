{
  "name": "dataqna-golden-demo",
  "version": "1.0.0",
  "description": "Golden Demo for Data QnA API",
  "main": "build/index.js",
  "scripts": {
    "start": "node build/index.js",
    "build": "npm install && tsc && cd client && npm install && npm run build",
    "deploy": "npm run build && gcloud app deploy",
    "dev": "concurrently \"tsc --watch\" \"NODE_ENV=development nodemon build/index.js\" \"cd client && npm start\""
  },
  "engines": {
    "npm": "10.9.2",
    "node": "22.x.x"
  },
  "dependencies": {
    "@google-cloud/geminidataanalytics": "^0.7.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/vertexai": "^1.10.3",
    "@grpc/grpc-js": "^1.14.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-ws": "^5.0.2",
    "google-auth-library": "^9.15.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/express-ws": "^3.0.6",
    "@types/node": "^20.19.37",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.9",
    "typescript": "^5.9.3"
  }
}
